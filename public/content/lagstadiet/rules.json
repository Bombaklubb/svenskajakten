      "id": "specialbokstaver",
      "title": "Svenska specialbokstäver",
      "icon": "🇸🇪",
      "content": [
        {
          "term": "Å (å)",
          "explanation": "Används i ord som 'år', 'åka', 'hål'.",
          "examples": ["år", "åka", "hål", "gå", "stå"]
        },
        {
          "term": "Ä (ä)",
          "explanation": "Används i ord som 'äta', 'äpple', 'bär'.",
          "examples": ["äta", "äpple", "bär", "läsa", "häst"]
        },
        {
          "term": "Ö (ö)",
          "explanation": "Används i ord som 'öga', 'öra', 'böcker'.",
          "examples": ["öga", "öra", "böcker", "söt", "grön"]
        }
      ]
    },
    {
      "id": "meningsbyggnad",
      "title": "Hur man bygger en mening",
      "icon": "🏗️",
      "content": [
        {
          "term": "En mening börjar med stor bokstav",
          "explanation": "Det första ordet i en mening skrivs alltid med stor bokstav.",
          "examples": ["Hunden springer.", "Katten sover.", "Barnen leker."]
        },
        {
          "term": "En mening slutar med punkt",
          "explanation": "När meningen är klar sätter man en punkt (.) i slutet.",
          "examples": ["Jag heter Maja.", "Vi bor i Sverige.", "Solen skiner."]
        }
