      "id": "ordklasser",
      "title": "Ordklasser",
      "icon": "📝",
      "content": [
        {
          "term": "Substantiv",
          "explanation": "Namn på saker, djur och personer.",
          "examples": ["hund", "boll", "flicka", "hus", "skola"]
        },
        {
          "term": "Verb",
          "explanation": "Ord som beskriver handlingar – vad man gör.",
          "examples": ["springer", "äter", "sover", "leker", "hoppar"]
        },
        {
          "term": "Adjektiv",
          "explanation": "Ord som beskriver hur något ser ut eller är.",
          "examples": ["stor", "liten", "glad", "röd", "söt"]
        }
      ]
    },
    {
      "id": "specialbokstaver",
      "title": "Svenska specialbokstäver",
      "icon": "🇸🇪",
      "content": [
        {
          "term": "Å (å)",
          "explanation": "Används i ord som 'år', 'åka', 'hål'.",
          "examples": ["år", "åka", "hål", "gå", "stå"]
        },
        {
          "term": "Ä (ä)",
          "explanation": "Används i ord som 'äta', 'äpple', 'bär'.",
          "examples": ["äta", "äpple", "bär", "läsa", "häst"]
        },
        {
          "term": "Ö (ö)",
          "explanation": "Används i ord som 'öga', 'öra', 'böcker'.",
          "examples": ["öga", "öra", "böcker", "söt", "grön"]
        }
      ]
    },
    {
      "id": "meningsbyggnad",
      "title": "Hur man bygger en mening",
      "icon": "🏗️",
      "content": [
        {
          "term": "En mening börjar med stor bokstav",
          "explanation": "Det första ordet i en mening skrivs alltid med stor bokstav.",
          "examples": ["Hunden springer.", "Katten sover.", "Barnen leker."]
        },
        {
          "term": "En mening slutar med punkt",
          "explanation": "När meningen är klar sätter man en punkt (.) i slutet.",
          "examples": ["Jag heter Maja.", "Vi bor i Sverige.", "Solen skiner."]
        },
        {
          "term": "En fråga slutar med frågetecken",
          "explanation": "Frågor avslutas alltid med frågetecken (?).",
          "examples": ["Vad heter du?", "Hur mår du?", "Var bor du?"]
        },
        {
          "term": "Namn börjar med stor bokstav",
          "explanation": "Namn på personer och platser skrivs alltid med stor bokstav.",
          "examples": ["Anna", "Kalle", "Sverige", "Stockholm", "Göteborg"]
        }
      ]
    },
    {
      "id": "vanliga-fel",
      "title": "Vanliga fel att undvika",
      "icon": "⚠️",
      "content": [
        {
          "term": "Dubbelteckning",
          "explanation": "Kort vokal följs av dubbel konsonant. Lång vokal följs av enkel konsonant.",
          "examples": ["katt (kort a) men mat (långt a)", "glass (kort a) men glas (långt a)", "boll (kort o) men bol (finns ej)"]
        },
        {
          "term": "Glöm inte specialbokstäverna",
          "explanation": "Svenska har å, ä och ö – blanda inte ihop dem med a och o.",
          "examples": ["äpple (inte apple)", "öga (inte oga)", "år (inte ar)"]
        },
        {
          "term": "Sammansatta ord skrivs ihop",
          "explanation": "På svenska skrivs sammansatta ord som ett ord, inte som två.",
          "examples": ["skolbuss (inte skol buss)", "hundhus (inte hund hus)", "solros (inte sol ros)"]
        }
      ]
    }
  ]
}
