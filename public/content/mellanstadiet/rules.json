{
  "sections": [
    {
      "id": "satsdelar",
      "title": "Satsdelar",
      "icon": "🔍",
      "content": [
        {
          "term": "Subjekt",
          "explanation": "Den som utför handlingen i meningen. Svarar på frågan 'Vem?' eller 'Vad?'",
          "examples": ["Lisa läser.", "Hunden springer.", "De leker."]
        },
        {
          "term": "Predikat",
          "explanation": "Verbet i meningen – vad subjektet gör.",
          "examples": ["Lisa läser.", "Hunden springer.", "Vi spelar fotboll."]
        },
        {
          "term": "Objekt",
          "explanation": "Det som handlingen riktas mot. Svarar på 'Vem?' eller 'Vad?' efter predikatet.",
          "examples": ["Jag äter en smörgås.", "Han läser en bok.", "Vi ser filmen."]
        },
        {
          "term": "Adverbial",
          "explanation": "Bestämmer hur, när eller var något händer.",
          "examples": ["Vi spelar i parken. (var?)", "Hon sjunger vackert. (hur?)", "De kom igår. (när?)"]
        }
      ]
    },
    {
      "id": "tempus",
      "title": "Tempus (tidsformer)",
      "icon": "⏰",
      "content": [
        {
          "term": "Presens (nutid)",
          "explanation": "Något händer nu.",
          "examples": ["Jag läser.", "De springer.", "Hon sjunger."]
        },
        {
          "term": "Preteritum (dåtid)",
          "explanation": "Något hände förr. Lägg ofta till -ade, -te eller ändra vokalen.",
          "examples": ["Jag läste.", "De sprang.", "Hon sjöng."]
        },
        {
          "term": "Perfekt",
          "explanation": "Något har hänt och är kopplat till nutiden. Använd 'har' + supinum.",
          "examples": ["Jag har läst boken.", "De har sprungit.", "Hon har sjungit."]
        }
      ]
    },
    {
      "id": "pronomen",
      "title": "Pronomen",
      "icon": "👥",
      "content": [
        {
          "term": "Personliga pronomen",
          "explanation": "Ersätter namn och substantiv för att undvika upprepning.",
          "examples": ["jag, du, han, hon, det, vi, ni, de"]
        },
        {
          "term": "Reflexiva pronomen",
          "explanation": "Syftar tillbaka på subjektet.",
          "examples": ["sig, mig, dig, oss, er"]
        }
      ]
    },
    {
      "id": "adjektiv-adverb",
      "title": "Adjektiv och adverb",
      "icon": "🌈",
      "content": [
        {
          "term": "Adjektiv",
          "explanation": "Beskriver ett substantiv – hur något är.",
          "examples": ["en stor bil", "en snäll lärare", "ett gult hus"]
        },
        {
          "term": "Adverb",
          "explanation": "Beskriver ett verb – hur något görs. Slutar ofta på -t.",
          "examples": ["springer snabbt", "sjunger vackert", "bor nära"]
        }
      ]
    },
    {
      "id": "sj-tj-ng-ljud",
      "title": "Sj-, tj- och ng-ljud",
      "icon": "🔤",
      "content": [
        {
          "term": "Sj-ljud",
          "explanation": "Kan skrivas: sj, sk (före e/i/y/ä/ö), skj, stj, sch, ch.",
          "examples": ["sjunga, skämt, skjuta, stjärna, schema, chef"]
        },
        {
          "term": "Tj-ljud",
          "explanation": "Kan skrivas: tj, k (före e/i/y/ä/ö), kj.",
          "examples": ["tjuv, kyckling, kyss, kärlek, kjol"]
        },
        {
          "term": "Ng-ljud",
          "explanation": "Skrivs 'ng'. Förekommer i slutet av stavelser.",
          "examples": ["sång, ring, lång, ingenting, något"]
        }
      ]
    },
    {
      "id": "skiljetecken",
      "title": "Skiljetecken",
      "icon": "⁉️",
      "content": [
        {
          "term": "Punkt (.)",
          "explanation": "Avslutar en påståendemening.",
          "examples": ["Jag heter Maja.", "Solen skiner idag."]
        },
        {
          "term": "Kommatecken (,)",
          "explanation": "Används vid uppräkningar, inskott och ibland bisatser.",
          "examples": ["Jag köpte äpplen, päron och bananer.", "Ja, det stämmer."]
        },
        {
          "term": "Kolon (:)",
          "explanation": "Inleder en lista, förklaring eller direkt anföring.",
          "examples": ["Vi behöver: mjölk, bröd och ägg.", "Han sa: 'Hej!'"]
        },
        {
          "term": "Semikolon (;)",
          "explanation": "Förbinder två nära relaterade meningar utan konjunktion.",
          "examples": ["Det regnade; vi stannade inne.", "Hon kom tidigt; han kom sent."]
        }
      ]
    }
  ]
}
